{
  "manifest_version": 3,
  "name": "小红书排版助手 - 美化笔记排版工具",
  "version": "1.1.0",
  "description": "一键美化你的小红书笔记排版！调字号、行距、颜色、配色方案、排版模板，让每篇笔记都颜值在线。",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://www.xiaohongshu.com/*",
    "https://creator.xiaohongshu.com/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "小红书排版助手",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://creator.xiaohongshu.com/*/editor*",
        "https://creator.xiaohongshu.com/*/publish*",
        "https://creator.xiaohongshu.com/*/note*"
      ],
      "js": ["content/content.js"],
      "css": ["content/styles.css"],
      "run_at": "document_end"
    }
  ],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
